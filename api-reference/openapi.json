            "AegisEmail": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "amount",
                  "token",
                  "sourceChain",
                  "destinationChain",
                  "recipientAddress"
                ],
                "properties": {
                  "amount": {
                    "type": "string"
                  },
                  "token": {
                    "type": "string",
                    "enum": [
                      "USDC",
                      "EURC"
                    ]
                  },
                  "sourceChain": {
                    "type": "string"
                  },
                  "destinationChain": {
                    "type": "string"
                  },
                  "recipientAddress": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bridging request accepted"
          }
        },
        "parameters": [
          {
            "name": "X-Aegis-Email",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Agent email address"
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
