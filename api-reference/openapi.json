    "/v1/webhooks/circle": {
      "post": {
        "summary": "Receive Circle Webhook Events",
        "description": "Secure endpoint to process real-time notifications from Circle. Validates authenticity using a robust, constant-time HMAC-SHA256 comparison.",
        "tags": [
          "Webhooks API"
        ],
        "parameters": [
          {
            "name": "circle-signature",
            "in": "header",
            "required": true,
            "description": "HMAC-SHA256 signature calculated over raw body using webhooks secret",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook notification accepted"
          },
          "401": {
            "description": "Invalid webhook signature"
          }
        }
      }
    },
    "/v1/marketplace/search": {
      "post": {
        "summary": "Search Marketplace Catalog",
        "description": "Query, paginate, and search the Circle Marketplace service resources catalog by keyword, type, or category.",
        "tags": [
          "Marketplace API (x402)"
        ],
        "security": [
          {
            "BearerAuth": []
          },
          {
            "AegisEmail": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keyword": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer",
                    "maximum": 50
                  },
                  "offset": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Marketplace services searched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "results": {
                      "type": "object",
                      "properties": {
                        "services": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        },
                        "total": {
                          "type": "integer"
                        },
                        "limit": {
                          "type": "integer"
                        },
                        "offset": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-Aegis-Email",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Agent email address"
          }
        ]
      }
    },
